# ── Server ────────────────────────────────────────────────
API_PORT=4000
FRONTEND_PORT=3000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────
# Local: path to SQLite file
DATABASE_URL=./lib/db/db/dev.db
# Production (Railway): set this to /app/data/prod.db

# ── Google OAuth (optional) ────────────────────────────────
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local:
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
# Production:
# GOOGLE_REDIRECT_URI=https://YOUR-APP-NAME.railway.app/api/auth/google/callback
# FRONTEND_URL=https://YOUR-PROJECT.vercel.app

# ── Admin seed (used by scripts/seed-admin.mjs) ────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe@123
ADMIN_USERNAME=admin

# ── Vercel (frontend build) ─────────────────────────────────
# Set this in Vercel dashboard → Project Settings → Environment Variables
# VITE_API_URL=https://YOUR-APP-NAME.railway.app
