{
  "version": 2,
  "installCommand": "npm install -g pnpm && pnpm install --frozen-lockfile --ignore-scripts",
  "buildCommand": "pnpm --filter @workspace/api-client-react build && pnpm --filter @workspace/traffic-peak run build && mv artifacts/traffic-peak/dist/public public",
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
